pipeline {
    agent any

    environment {
        NODE_OPTIONS     = '--max-old-space-size=4096'
        SONAR_HOST_URL   = 'http://100.105.57.78:9000'
        SONAR_PROJECT_KEY = 'employee-recommendation-backend'
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 30, unit: 'MINUTES')
        timestamps()
    }

    stages {

        // ─── 1. Checkout ──────────────────────────────────────────
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        // ─── 2. Install ───────────────────────────────────────────
        stage('Install Dependencies') {
            steps {
                dir('backend') {
                    sh 'npm ci --prefer-offline --no-audit --no-fund || npm install --legacy-peer-deps'
                }
            }
        }

        // ─── 3. Tests + Coverage ──────────────────────────────────
        //        MUST run BEFORE SonarQube
        stage('Tests & Coverage') {
            steps {
                dir('backend') {
                    sh '''
                        # Run Jest with coverage — generates coverage/lcov.info
                        npx jest --coverage --coverageDirectory=coverage \
                            --coverageReporters=lcov \
                            --collectCoverageFrom="src/**/*.ts" \
                            --collectCoverageFrom="!src/**/*.spec.ts" \
                            --collectCoverageFrom="!src/**/*.module.ts" \
                            --collectCoverageFrom="!src/main.ts" \
                            --passWithNoTests

                        # Verify the file was created
                        if [ ! -f coverage/lcov.info ]; then
                            echo "ERROR: coverage/lcov.info not generated"
                            exit 1
                        fi

                        echo "=== COVERAGE SUMMARY ==="
                        TOTAL_LF=$(grep -E "^LF:" coverage/lcov.info | awk -F: \'{sum+=$2} END {print sum}\')
                        TOTAL_LH=$(grep -E "^LH:" coverage/lcov.info | awk -F: \'{sum+=$2} END {print sum}\')
                        echo "Lines Found : $TOTAL_LF"
                        echo "Lines Hit   : $TOTAL_LH"
                        echo "First SF entries in lcov:"
                        grep "^SF:" coverage/lcov.info | head -5
                    '''
                }
            }
            post {
                always {
                    // Archive coverage so it can be inspected in Jenkins
                    archiveArtifacts artifacts: 'backend/coverage/lcov.info', allowEmptyArchive: true
                }
            }
        }

        // ─── 4. SonarQube Analysis ────────────────────────────────
        //        Reads coverage/lcov.info generated in step above
        stage('SonarQube Analysis') {
            steps {
                dir('backend') {
                    withSonarQubeEnv('SonarQube') {
                        sh '''
                            echo "Running SonarQube scanner..."

                            sonar-scanner \
                                -Dsonar.projectKey=${SONAR_PROJECT_KEY} \
                                -Dsonar.projectName="Employee Recommendation Backend" \
                                -Dsonar.sources=src \
                                -Dsonar.tests=src \
                                -Dsonar.test.inclusions="**/*.spec.ts,**/*.test.ts" \
                                -Dsonar.exclusions="**/node_modules/**,**/dist/**,**/coverage/**,**/uploads/**" \
                                -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info \
                                -Dsonar.typescript.lcov.reportPaths=coverage/lcov.info \
                                -Dsonar.host.url=${SONAR_HOST_URL} \
                                -Dsonar.token=${SONAR_TOKEN}
                        '''
                    }
                }
            }
        }
    }

    post {
        success { echo 'Pipeline OK' }
        failure { echo 'Pipeline FAILED — check logs' }
    }
}
