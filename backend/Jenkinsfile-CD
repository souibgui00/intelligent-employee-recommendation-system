pipeline {
    agent any

    environment {
        PATH = "/usr/bin:/usr/local/bin:${env.PATH}"
        KUBECONFIG = '/var/lib/jenkins/.kube/config'    // ← add this line
    }

    stages {

        stage('📥 Checkout') {
            steps {
                checkout scm
            }
        }

        stage('🐳 Build Docker Image') {
            steps {
                dir('backend') {
                    sh '''
                        docker build -t mon-backend:latest .
                        docker tag mon-backend:latest mon-backend:${BUILD_NUMBER}
                    '''
                }
            }
        }

        stage('🚀 Deploy to Kubernetes') {
            steps {
                sh '''
                    kubectl apply -f k8s/backend-deployment.yaml --validate=false
                    kubectl rollout status deployment/backend-deployment --timeout=60s
                '''
            }
        }

        stage('🔎 Verify Deployment') {
            steps {
                sh '''
                    kubectl get pods -l app=backend
                    kubectl get services
                '''
            }
        }
    }

    post {
        success {
            echo '✅ CD Backend déployé avec succès !'
        }
        failure {
            echo '❌ Déploiement échoué — rollback...'
            sh 'kubectl rollout undo deployment/backend-deployment || true'
        }
    }
}
