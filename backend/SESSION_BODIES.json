{
  "session_management": {
    "login": {
      "description": "POST /auth/login - Create session and get tokens",
      "body": {
        "email": "admin@test.com",
        "password": "admin123"
      },
      "response": {
        "access_token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
        "refresh_token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
        "expiresIn": 900,
        "user": {}
      }
    },
    "refresh": {
      "description": "POST /auth/refresh - Get new access token using refresh token",
      "body": {
        "refreshToken": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
      },
      "response": {
        "access_token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
        "refresh_token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
        "expiresIn": 900
      }
    },
    "logout": {
      "description": "POST /auth/logout - Revoke session (logout from one device)",
      "body": {
        "refreshToken": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
      },
      "response": {
        "message": "Logged out successfully"
      }
    },
    "logout_all": {
      "description": "POST /auth/logout-all - Logout from all devices",
      "headers": {
        "Authorization": "Bearer YOUR_ACCESS_TOKEN"
      },
      "body": {},
      "response": {
        "message": "Logged out from all devices"
      }
    }
  },
  "token_lifespan": {
    "access_token": {
      "expires_in": "15 minutes",
      "description": "Short-lived, used for API requests",
      "security": "If stolen, attacker has limited time"
    },
    "refresh_token": {
      "expires_in": "7 days",
      "description": "Long-lived, used to get new access tokens",
      "security": "Stored in database, can be revoked anytime"
    }
  },
  "workflow_example": {
    "step_1_login": {
      "time": "9:00 AM",
      "action": "User logs in",
      "endpoint": "POST /auth/login",
      "result": "Gets access_token (valid until 9:15 AM) + refresh_token (valid until March 3)"
    },
    "step_2_use_app": {
      "time": "9:05 AM",
      "action": "User uses app (calls API endpoints)",
      "endpoint": "GET /users with Authorization: Bearer access_token",
      "result": "Access token is valid, request succeeds"
    },
    "step_3_token_expires": {
      "time": "9:15 AM",
      "action": "Access token expires automatically",
      "result": "Next API call returns 401 Unauthorized"
    },
    "step_4_refresh_token": {
      "time": "9:15 AM",
      "action": "Frontend/app calls refresh endpoint",
      "endpoint": "POST /auth/refresh with refresh_token",
      "result": "Gets new access_token (valid until 9:30 AM)"
    },
    "step_5_continue_working": {
      "time": "9:20 AM",
      "action": "User continues using app with new token",
      "endpoint": "GET /skills with new access_token",
      "result": "Works seamlessly, user doesn't notice token refresh"
    },
    "step_6_logout": {
      "time": "12:00 PM (or whenever user logs out)",
      "action": "User clicks logout button",
      "endpoint": "POST /auth/logout with refresh_token",
      "result": "Session revoked in DB, old tokens become invalid"
    },
    "step_7_cannot_use_old_tokens": {
      "time": "12:01 PM onwards",
      "action": "Try to use old refresh token",
      "endpoint": "POST /auth/refresh with old refresh_token",
      "result": "401 Unauthorized - Session is revoked"
    }
  },
  "multi_device_scenario": {
    "laptop": {
      "login_body": {
        "email": "admin@test.com",
        "password": "admin123"
      },
      "result": "Session 1 created, refresh_token_1 generated"
    },
    "phone": {
      "login_body": {
        "email": "admin@test.com",
        "password": "admin123"
      },
      "result": "Session 2 created, refresh_token_2 generated (independent from laptop)"
    },
    "tablet": {
      "login_body": {
        "email": "admin@test.com",
        "password": "admin123"
      },
      "result": "Session 3 created, refresh_token_3 generated (independent from laptop and phone)"
    },
    "logout_single_device": {
      "action": "Logout from laptop only",
      "endpoint": "POST /auth/logout",
      "body": {
        "refreshToken": "refresh_token_1"
      },
      "result": "Only Session 1 revoked, phone and tablet still logged in"
    },
    "logout_all_devices": {
      "action": "Logout from all devices",
      "endpoint": "POST /auth/logout-all",
      "headers": {
        "Authorization": "Bearer access_token"
      },
      "result": "Sessions 1, 2, and 3 all revoked, must login again on all devices"
    }
  }
}
