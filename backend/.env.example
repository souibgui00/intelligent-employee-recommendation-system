## Backend environment variables

# MongoDB connection string (required)
MONGODB_URI="mongodb://localhost:27017/pi_techbuilders"

# JWT signing secret (required) - use a long random value in production
JWT_SECRET="change-me-to-a-long-random-secret"

# Server port (optional)
PORT=3001

# Google OAuth 2.0 (fill with your own values from Google Cloud Console)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
# Typically http://localhost:3001/auth/google/callback in dev
GOOGLE_CALLBACK_URL="http://localhost:3001/auth/google/callback"
FRONTEND_URL="http://localhost:5173"

