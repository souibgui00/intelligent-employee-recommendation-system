{
  "compilerOptions": {
    "module": "Node16",
    "target": "ES2021",
    "moduleResolution": "node16",
    "types": ["node", "jest"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "sourceMap": true
  }
}
