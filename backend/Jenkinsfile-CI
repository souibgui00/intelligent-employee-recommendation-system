pipeline {
    agent any

    tools {
        nodejs 'NodeJS-20'
    }

    stages {
        stage('📥 Checkout') {
            steps {
                checkout scm
            }
        }

        stage('📦 Install') {
            steps {
                dir('backend') {
                    retry(3) {
                        sh 'npm install --prefer-offline --fetch-timeout=600000'
                    }
                }
            }
        }

        stage('🧪 Tests') {
            steps {
                dir('backend') {
                    // Using the NestJS coverage command we verified locally
                    sh 'npm run test:cov'
                }
            }
        }

        stage('🏗️ Build') {
            steps {
                dir('backend') {
                    sh 'npm run build'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir('backend') {
                    sh '''/opt/sonar-scanner/bin/sonar-scanner \
                        -Dsonar.projectKey=backend \
                        -Dsonar.sources=src \
                        -Dsonar.host.url=http://localhost:9000 \
                        -Dsonar.login=squ_3638fe03cb73ea0e15f747beb004d1493dafa066 \
                        -Dsonar.typescript.lcov.reportPaths=coverage/lcov.info \
                        -Dsonar.testExecutionReportPaths=test-report.xml || true'''
                }
            }
        }

        stage('🐳 Docker Build') {
            steps {
                dir('backend') {
                    sh '''
                        docker build -t mon-backend:${BUILD_NUMBER} .
                        docker tag mon-backend:${BUILD_NUMBER} mon-backend:latest
                    '''
                }
            }
        }

        stage('🔒 Trivy Scan') {
            steps {
                sh '''
                    trivy image \
                        --cache-dir /var/lib/jenkins/.cache/trivy \
                        --exit-code 0 \
                        --severity HIGH,CRITICAL \
                        --format table \
                        mon-backend:${BUILD_NUMBER}
                '''
            }
            post {
                always {
                    sh '''
                        trivy image \
                            --cache-dir /var/lib/jenkins/.cache/trivy \
                            --exit-code 0 \
                            --severity HIGH,CRITICAL \
                            --format json \
                            --output trivy-backend-report.json \
                            mon-backend:${BUILD_NUMBER}
                    '''
                    archiveArtifacts artifacts: 'trivy-backend-report.json', fingerprint: true
                }
            }
        }
    }

    post {
        success {
            echo '✅ Backend CI completed successfully!'
            // Trigger Backend CD job
            build job: 'CD-Backend', wait: false
        }
    }
}