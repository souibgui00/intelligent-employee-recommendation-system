pipeline {
    agent any

    environment {
        PATH = "/usr/bin:/usr/local/bin:${env.PATH}"
        KUBECONFIG = '/var/lib/jenkins/.kube/config'
        IMAGE_NAME = 'mon-backend'
        NAMESPACE = 'default'
    }

    stages {

        stage('📥 Checkout') {
            steps {
                checkout scm
            }
        }

        stage('🐳 Build Docker Image') {
            steps {
                dir('backend') {
                    sh '''
                        docker build -t ${IMAGE_NAME}:latest .
                        docker tag ${IMAGE_NAME}:latest ${IMAGE_NAME}:${BUILD_NUMBER}
                    '''
                }
            }
        }

        stage('🔧 Setup Kubeconfig') {
            steps {
                sh '''
                    mkdir -p /var/lib/jenkins/.kube
                    cp /etc/kubernetes/admin.conf /var/lib/jenkins/.kube/config
                    chown jenkins:jenkins /var/lib/jenkins/.kube/config
                    kubectl get nodes
                '''
            }
        }

        stage('🚀 Deploy to Kubernetes') {
            steps {
                sh '''
                    kubectl apply -f k8s/backend-deployment.yaml \
                        --validate=false \
                        -n ${NAMESPACE}
                    kubectl rollout status deployment/backend-deployment \
                        -n ${NAMESPACE} \
                        --timeout=120s
                '''
            }
        }

        stage('🔎 Verify Deployment') {
            steps {
                sh '''
                    kubectl get pods -l app=backend -n ${NAMESPACE}
                    kubectl get services -n ${NAMESPACE}
                '''
            }
        }
    }

    post {
        success {
            echo '✅ CD Backend déployé avec succès !'
        }
        failure {
            echo '❌ Déploiement échoué — rollback...'
            sh 'kubectl rollout undo deployment/backend-deployment -n ${NAMESPACE} || true'
        }
    }
}
