pipeline {
    agent any

    options {
        disableConcurrentBuilds()
    }

    tools {
        nodejs 'NodeJS-20'
    }

    stages {

        stage('📥 Checkout') {
            steps {
                checkout scm
            }
        }

        stage('📦 Install') {
            steps {
                dir('frontend') {
                    sh 'rm -rf node_modules'
                    retry(3) {
                        sh 'npm install --prefer-offline --fetch-timeout=600000 --fetch-retry-mintimeout=20000 --fetch-retry-maxtimeout=120000'
                    }
                }
            }
        }

        stage('🧪 Tests') {
            steps {
                dir('frontend') {
                    sh 'npm test -- --watchAll=false --coverage'
                    sh 'sed -i "s|\\\\|/|g" coverage/lcov.info || true'
                }
            }
        }

        stage('🏗️ Build') {
            steps {
                dir('frontend') {
                    sh 'npx vite build'
                }
            }
        }

        stage('🔍 SonarQube Analysis') {
            steps {
                dir('frontend') {
                    sh '''/opt/sonar-scanner/bin/sonar-scanner \
                        -Dsonar.projectKey=frontend \
                        -Dsonar.sources=app,components,lib,src \
                        -Dsonar.exclusions=**/node_modules/**,**/dist/**,**/.vite/**,**/coverage/**,**/.scannerwork/**,**/public/**,**/*.json,**/*.md,**/*.yml,**/*.yaml,**/*.lock,**/components/ui/** \
                        -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info \
                        -Dsonar.coverage.exclusions=**/node_modules/**,**/dist/**,**/*.test.*,**/*.spec.*,**/components/ui/** \
                        -Dsonar.host.url=http://localhost:9000 \
                        -Dsonar.token=squ_df2da35f30d9d1bb68bcb12bf28b1f3ee12ba61a

'''
                }
            }
        }

        stage('🐳 Docker Build') {
            steps {
                dir('frontend') {
                    sh '''
                        docker build -t mon-frontend:${BUILD_NUMBER} .
                        docker tag mon-frontend:${BUILD_NUMBER} mon-frontend:latest
                    '''
                }
            }
        }

    }

    post {
        success {
            build job: 'CD-Frontend', wait: false
        }
        always {
            echo '🏁 Frontend CI pipeline completed'
        }
        failure {
            echo '❌ Frontend CI pipeline failed'
        }
    }
}
