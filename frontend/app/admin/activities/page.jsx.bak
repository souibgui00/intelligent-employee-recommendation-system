"use client"

import { useState } from "react"

import { ActivityList } from "@/components/activities/activity-list"
import { DashboardHeader } from "@/components/dashboard/header"`nimport { ActivityDetail } from "@/components/activities/activity-detail"

export default function AdminActivitiesPage() {
  const [selectedActivity, setSelectedActivity] = useState(null)

  return (
    <div className="flex flex-col bg-[#F8FAFC] min-h-screen">
      <DashboardHeader title="Dashboard" description="Professional workspace interface" />

      <div className="flex-1 p-8 space-y-8 animate-in fade-in slide-in-from-bottom-2 duration-500">
        <div className="flex items-center justify-between pb-6 border-b border-gray-200">
          <div>
            <p className="text-xs font-medium text-[#F28C1B] uppercase tracking-widest mb-1">Administration</p>
            <h1 className="text-2xl font-semibold text-gray-900">Activity Management</h1>
            <p className="text-sm text-gray-500 mt-1">Create, edit and manage all training activities and programs.</p>
          </div>
        </div>

        <div className="grid gap-10 lg:grid-cols-3 items-start">
          <div className={selectedActivity ? "lg:col-span-2" : "lg:col-span-3 transition-all"}>
            <div className="bg-white rounded-[4px] border border-[#EEEEEE] p-0 shadow-sm overflow-hidden transition-all group relative">
              <div className="absolute top-0 right-0 w-32 h-32 bg-[#F28C1B]/[0.02] rounded-full -mr-16 -mt-16 pointer-events-none group-hover:bg-[#F28C1B]/[0.05] transition-all"></div>
              <ActivityList
                onSelectActivity={setSelectedActivity}
                selectedActivityId={selectedActivity?.id}
              />
            </div>
          </div>
          {selectedActivity && (
            <div className="lg:col-span-1 animate-in slide-in-from-right-10 duration-700">
              <div className="bg-white rounded-[4px] border border-[#EEEEEE] shadow-2xl overflow-hidden sticky top-8">
                <ActivityDetail
                  activity={selectedActivity}
                  onClose={() => setSelectedActivity(null)}
                />
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  )
}






